# ============================================================
# pdf-to-obsidian Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env   (Mac/Linux)
#   copy .env.example .env (Windows)
# Or run: python setup.py
# ============================================================

# Required: Your Gemini API key
# Get one free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Required: Absolute path to your Obsidian vault folder
# Examples:
#   Windows: C:\Users\YourName\Documents\My Vault
#   Mac:     /Users/yourname/Documents/My Vault
#   Linux:   /home/yourname/Documents/My Vault
OBSIDIAN_VAULT_PATH=

# Optional: AI model to use (default: gemini-3.5-flash)
# GEMINI_MODEL=gemini-3.5-flash

# Optional: PDF rendering quality in DPI (default: 300)
# PDF_DPI=300

# Optional: Max API retries on failure (default: 5)
# MAX_RETRIES=5
